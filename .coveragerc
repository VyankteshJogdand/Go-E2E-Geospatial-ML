[html]
directory = coverage

[run]
source =
    instageo
omit =
    */__init__.py
    *_test.py
    */seamless_seg.py

[report]
omit =
    __init__.py
    *_test.py
    *app.py
    */seamless_seg.py

exclude_lines =
    # Don't complain if tests don't hit defensive assertion code:
    raise AssertionError
    raise NotImplementedError

    # Don't complain if non-runnable code isn't run:
    if 0:
    if __name__ == .__main__.:
